{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node", "jest"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",

    // 🔥 Ajout indispensable :
    "src/pipelines"
  ]
}
